# ---- XENOKING backend config ----
# Copy this file to ".env" for local runs, or set these as environment
# variables in your host's dashboard (Render: Environment tab).

# The single owner (you). This account can approve/ban/block everyone else.
OWNER_EMAIL=you@example.com
OWNER_PASSWORD=change-this-to-a-strong-password
OWNER_NAME=Owner

# Secret used to sign login tokens. Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long a login stays valid.
JWT_TTL=7d

# Port to listen on (Render sets PORT automatically — you can omit it there).
PORT=8080

# ---- Where accounts are stored ----
# Option A (free-tier hosting like Render): use Turso (free cloud SQLite) so
# your user list survives restarts/redeploys. Get both values from
# https://turso.tech after creating a database:
# DATABASE_URL=libsql://your-db-name-your-user.turso.io
# DATABASE_AUTH_TOKEN=paste-the-token-here
#
# Option B (a VPS / anywhere with a real disk): leave both unset and accounts
# are stored in a local file under DATA_DIR.
DATA_DIR=./data

# Optional: lock the API to specific origins (comma separated). Leave blank to
# allow any origin (fine here — auth is via bearer token, not cookies).
# ALLOWED_ORIGINS=chrome-extension://yourextensionid
