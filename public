
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>XENOKING — Owner Console</title>
<style>
  :root{ --cyan:#25e6ff; --purple:#a855f7; --pink:#ff3d81; --txt:#eaf0ff; --muted:#8a95b8;
    --line:rgba(130,150,230,.18); --grad:linear-gradient(135deg,#25e6ff,#8b5cf6 55%,#ff3d81); }
  *{ box-sizing:border-box; }
  body{ margin:0; font:14px/1.55 system-ui,"Segoe UI",Roboto,sans-serif; color:var(--txt);
    background:radial-gradient(120% 90% at 12% -10%,rgba(37,230,255,.14),transparent 55%),
    radial-gradient(120% 90% at 100% 110%,rgba(255,61,129,.14),transparent 55%),#05060c; min-height:100vh; }
  .wrap{ max-width:820px; margin:0 auto; padding:30px 16px 70px; }
  .brand{ text-align:center; margin-bottom:22px; }
  .brand .word{ font-size:30px; font-weight:900; letter-spacing:6px; background:var(--grad);
    -webkit-background-clip:text; background-clip:text; color:transparent; filter:drop-shadow(0 0 18px rgba(139,92,246,.45)); }
  .brand .tag{ color:var(--muted); font-size:11px; letter-spacing:5px; font-weight:700; }
  .emblem{ width:64px; height:64px; filter:drop-shadow(0 0 12px rgba(37,230,255,.5)); }
  .card{ position:relative; background:rgba(16,20,36,.72); border:1px solid var(--line); border-radius:18px; padding:22px; backdrop-filter:blur(12px); }
  label{ display:block; font-size:11px; text-transform:uppercase; letter-spacing:.5px; color:var(--muted); margin:12px 0 5px; font-weight:700; }
  input,select{ width:100%; padding:11px 13px; background:rgba(6,9,18,.85); border:1px solid var(--line); border-radius:11px; color:var(--txt); font-size:14px; }
  input:focus,select:focus{ outline:none; border-color:var(--cyan); box-shadow:0 0 0 3px rgba(37,230,255,.16); }
  button{ cursor:pointer; border:0; border-radius:11px; padding:11px 15px; font-weight:800; color:#06070c; background:var(--grad); box-shadow:0 8px 22px -8px rgba(139,92,246,.7); }
  button:hover{ filter:brightness(1.06); } button:disabled{ opacity:.5; cursor:default; }
  button.ghost{ background:transparent; color:var(--txt); border:1px solid var(--line); box-shadow:none; }
  button.approve{ background:linear-gradient(135deg,#2ee6a6,#12b981); color:#04120c; box-shadow:none; }
  button.block{ background:linear-gradient(135deg,#ffb020,#f7861f); color:#1a0f00; box-shadow:none; }
  button.ban{ background:linear-gradient(135deg,#ff5b7a,#e0294b); color:#fff; box-shadow:none; }
  button.del{ background:rgba(255,91,122,.12); color:#ff8ea0; border:1px solid rgba(255,91,122,.3); box-shadow:none; }
  .row{ display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
  .between{ display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap; }
  .hidden{ display:none; }
  .chip{ padding:3px 10px; border-radius:999px; background:rgba(255,255,255,.05); border:1px solid var(--line); color:var(--muted); font-size:12px; font-weight:700; }
  .ucard{ padding:12px; border-radius:14px; background:rgba(255,255,255,.03); border:1px solid var(--line); margin-top:10px; }
  .uhead{ display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
  .uemail{ font-weight:700; word-break:break-all; } .uname,.uleft{ color:var(--muted); font-size:12px; } .uleft b{ color:var(--cyan); }
  .pill{ padding:3px 10px; border-radius:999px; font-size:11px; font-weight:800; white-space:nowrap; }
  .pill.pending{ background:rgba(255,176,32,.14); color:#ffcf6b; } .pill.approved{ background:rgba(46,230,166,.14); color:#5fe3a8; }
  .pill.banned{ background:rgba(255,91,122,.14); color:#ff90a2; } .pill.blocked{ background:rgba(255,140,50,.14); color:#ffab6b; }
  .pill.expired{ background:rgba(150,160,190,.14); color:#b9c2dc; }
  .uactions{ display:flex; gap:7px; align-items:center; flex-wrap:wrap; margin-top:11px; }
  select.dur{ width:auto; padding:7px 9px; font-size:12px; font-weight:700; } .uactions button{ padding:7px 11px; font-size:12px; }
  .err{ color:#ff8ea0; min-height:18px; margin-top:10px; font-weight:600; }
  .empty{ text-align:center; color:var(--muted); padding:22px; }
  .login{ max-width:420px; margin:0 auto; }
</style>
</head>
<body>
<div class="wrap">
  <div class="brand">
    <svg class="emblem" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="g" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse"><stop stop-color="#25e6ff"/><stop offset=".55" stop-color="#8b5cf6"/><stop offset="1" stop-color="#ff3d81"/></linearGradient></defs><path d="M60 6 108 33 108 87 60 114 12 87 12 33Z" fill="rgba(10,14,28,.55)" stroke="url(#g)" stroke-width="3" stroke-linejoin="round"/><path d="M34 78 L29 45 L46 60 L60 35 L74 60 L91 45 L86 78 Z" fill="url(#g)"/><rect x="34" y="82" width="52" height="8" rx="2.5" fill="url(#g)"/></svg>
    <div class="word">XENOKING</div><div class="tag">OWNER CONSOLE</div>
  </div>

  <div id="loginCard" class="card login">
    <label>API base URL</label><input id="base" placeholder="https://your-server.com" />
    <label>Owner email</label><input id="email" type="email" autocomplete="username" />
    <label>Owner password</label><input id="password" type="password" autocomplete="current-password" />
    <div style="margin-top:16px"><button id="login">Log in</button></div>
    <div id="loginErr" class="err"></div>
  </div>

  <div id="dash" class="card hidden">
    <div class="between">
      <div class="row" id="counts"></div>
      <div class="row"><button class="ghost" id="refresh">Refresh</button><button class="ghost" id="logout">Log out</button></div>
    </div>
    <div id="rows"></div>
    <div id="dashErr" class="err"></div>
  </div>
</div>

<script>
const $=(id)=>document.getElementById(id);
let BASE=localStorage.getItem('xk_base')||location.origin, TOKEN=localStorage.getItem('xk_token')||'';
$('base').value=BASE;
async function api(p,o={}){const r=await fetch(BASE.replace(/\/$/,'')+p,{...o,headers:{'Content-Type':'application/json',...(TOKEN?{Authorization:'Bearer '+TOKEN}:{}),...(o.headers||{})}});const d=await r.json().catch(()=>({}));if(!r.ok)throw Object.assign(new Error(d.message||d.error||r.statusText),{data:d});return d;}
const esc=(s)=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
function show(on){$('loginCard').classList.toggle('hidden',on);$('dash').classList.toggle('hidden',!on);}
function durSel(){return '<select class="dur"><option value="0">Unlimited</option><option value="1">1 day</option><option value="3">3 days</option><option value="7">7 days</option><option value="14">14 days</option><option value="30" selected>30 days</option><option value="60">60 days</option><option value="90">90 days</option></select>';}
function accessLine(u){if(u.status!=='approved')return '';if(u.days_left==null)return '<div class="uleft"><b>Unlimited</b> access</div>';if(u.expired||u.days_left<=0)return '<div class="uleft">access <b>expired</b></div>';return '<div class="uleft"><b>'+u.days_left+'</b> day'+(u.days_left===1?'':'s')+' left</div>';}
async function load(){$('dashErr').textContent='';try{
  const {users}=await api('/api/admin/users');
  const list=users.filter(u=>u.role!=='owner');const c={pending:0,approved:0,blocked:0,banned:0,expired:0};
  $('rows').innerHTML=list.map(u=>{const expired=u.status==='approved'&&(u.expired||(u.days_left!=null&&u.days_left<=0));const key=expired?'expired':u.status;c[key]=(c[key]||0)+1;const primary=u.status==='approved'?(expired?'Renew':'Update'):'Approve';
    return '<div class="ucard" data-id="'+u.id+'"><div class="uhead"><div><div class="uemail">'+esc(u.email)+'</div>'+(u.name?'<div class="uname">'+esc(u.name)+'</div>':'')+accessLine(u)+'</div><span class="pill '+key+'">'+(key==='approved'?'active':key)+'</span></div><div class="uactions">'+durSel()+'<button class="approve" data-a="approve">'+primary+'</button><button class="block" data-a="block">Block</button><button class="ban" data-a="ban">Ban</button><button class="del" data-a="delete">Delete</button></div></div>';
  }).join('')||'<div class="empty">No sign-ups yet.</div>';
  $('counts').innerHTML='<span class="chip">'+c.pending+' pending</span><span class="chip">'+c.approved+' active</span>'+(c.expired?'<span class="chip">'+c.expired+' expired</span>':'')+'<span class="chip">'+c.blocked+' blocked</span><span class="chip">'+c.banned+' banned</span>';
}catch(e){if(e.data&&(e.data.error==='owner_only'||e.data.error==='invalid_token'||e.data.error==='missing_token'))return logout();$('dashErr').textContent=e.message;}}
$('rows').addEventListener('click',async(ev)=>{const b=ev.target.closest('button[data-a]');if(!b)return;const card=b.closest('.ucard');const action=b.getAttribute('data-a');if(action==='delete'&&!confirm('Delete this user permanently?'))return;const sel=card.querySelector('.dur');const days=sel?Number(sel.value)||0:0;b.disabled=true;try{await api('/api/admin/users/'+card.dataset.id+'/'+action,{method:'POST',body:JSON.stringify({days})});await load();}catch(e){$('dashErr').textContent=e.message;b.disabled=false;}});
$('login').addEventListener('click',async()=>{$('loginErr').textContent='';BASE=$('base').value.trim()||location.origin;try{const {token}=await api('/api/login',{method:'POST',body:JSON.stringify({email:$('email').value.trim(),password:$('password').value})});TOKEN=token;localStorage.setItem('xk_token',TOKEN);localStorage.setItem('xk_base',BASE);show(true);load();}catch(e){$('loginErr').textContent=e.message;}});
function logout(){TOKEN='';localStorage.removeItem('xk_token');show(false);}
$('logout').addEventListener('click',logout);$('refresh').addEventListener('click',load);
if(TOKEN)api('/api/me').then(r=>{if(r.user&&r.user.role==='owner'){show(true);load();}else logout();}).catch(logout);
</script>
</body>
</html>
